{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "backend",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "cwd": "${workspaceRoot}/backend",
      "args": ["main:app", "--port", "8080"],
      "justMyCode": true
    },
    {
      "name": "Run react dev server",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}/frontend",
      "runtimeExecutable": "yarn",
      "env": {
        "PORT": "3007"
      },
      "runtimeArgs": ["start"]
    },
    {
      "name": "Run chrome debugger",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3007",
      "webRoot": "${workspaceFolder}/frontend"
    },
    {
      "type": "python",
      "request": "launch",
      "name": "Debug Load DB",
      "program": "${workspaceFolder}/bin/2-load-taxonomy.py",
      "cwd": "${workspaceFolder}",
      "args": ["--seed-only"]
    }
  ],
  "compounds": [
    {
      "name": "Debug frontend",
      "configurations": ["Run react dev server", "Run chrome debugger"]
    }
  ]
}
