{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run react dev server",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}/frontend",
      "runtimeExecutable": "yarn",
      "env": {
        "PORT": "3007"
      },
      "runtimeArgs": ["start"]
    },
    {
      "name": "Run chrome debugger",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3007",
      "webRoot": "${workspaceFolder}/frontend"
    },
    {
      "type": "python",
      "request": "launch",
      "name": "Debug Load DB",
      "program": "${workspaceFolder}/bin/3-load-rhea.py",
      "cwd": "${workspaceFolder}",
      "args": ["--load-db", "--number=10"]
    }
  ],
  "compounds": [
    {
      "name": "Debug frontend",
      "configurations": ["Run react dev server", "Run chrome debugger"]
    }
  ]
}
