{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "supabase start",
      "type": "shell",
      "command": "supabase start"
    },
    {
      "label": "supabase serve functions",
      "type": "shell",
      "command": "supabase functions serve --env-file supabase/.env.local"
    },
    {
      "label": "supabase stop",
      "type": "shell",
      "command": "supabase stop"
    },
    {
      "label": "supabase generate types",
      "type": "shell",
      "command": "supabase gen types typescript --local > frontend/src/database.types.ts"
    },
    {
      "label": "supabase test db",
      "type": "shell",
      "command": "supabase test db --debug"
    },
    {
      "label": "sqlalchemy generate types",
      "type": "shell",
      "command": "sqlacodegen postgresql://postgres:postgres@localhost:54322/postgres > bin/models.py && black bin/models.py"
    },
    {
      "label": "Start all",
      "dependsOn": ["supabase start", "supabase serve functions"],
      "problemMatcher": []
    }
  ]
}
