{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "supabase start",
      "type": "shell",
      "command": "supabase start"
    },
    {
      "label": "supabase stop",
      "type": "shell",
      "command": "supabase stop"
    },
    {
      "label": "supabase generate types",
      "type": "shell",
      "command": "supabase gen types typescript --local > frontend/src/database.types.ts"
    },
    {
      "label": "supabase serve api-key",
      "type": "shell",
      "command": "supabase functions serve api-key --env-file supabase/.env.local"
    },
    {
      "label": "supabase test db",
      "type": "shell",
      "command": "supabase test db --debug"
    },
    {
      "label": "sqlalchemy generate types",
      "type": "shell",
      "command": "sqlacodegen --generator sqlmodels postgresql://postgres:postgres@localhost:54322/postgres > bin/models.py && black bin/models.py"
    },
    {
      "label": "jupyter lab",
      "type": "shell",
      "command": "python -m jupyter lab"
    }
  ]
}
