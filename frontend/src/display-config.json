{
  "topLevelResources": ["chemical", "reaction", "protein", "species"],
  "listProperties": {
    "chemical": [
      {
        "property": "structure",
        "width": 150,
        "displayName": ""
      },
      "name"
    ],
    "reaction": ["name"],
    "species": ["name"],
    "protein": ["name", "short_name"]
  },
  "detailProperties": {
    "chemical": [
      {
        "property": "name",
        "gridSize": 6
      },
      {
        "property": "structure",
        "displayName": "",
        "gridSize": 6
      },
      "inchi",
      "inchi_key",
      "synonym",
      "notes",
      "reaction"
    ],
    "reaction": ["name", "stoichiometry", "synonym", "hash"],
    "species": ["name", "rank", "ncbi_tax_id", "notes"],
    "protein": ["name", "short_name", "sequence", "synonym"]
  },
  "propertyTypes": {
    "structure": {
      "type": "svg",
      "bucket": "structure_images_svg",
      "pathTemplate": "${id}${BRAINSHARE_UNDERSCORE_DARK}.svg"
    },
    "synonym": {
      "type": "sourceValue",
      "formattingRules": {
        "chebi": {
          "valueLink": "https://www.ebi.ac.uk/chebi/searchId.do?chebiId=${value}"
        },
        "rhea": {
          "valueLink": "https://www.rhea-db.org/rhea/${value}"
        },
        "metacyc": {
          "valueLink": "https://metacyc.org/gene?orgid=META&id=${value}"
        },
        "uniprot": {
          "valueLink": "https://www.uniprot.org/uniprotkb/${value}"
        }
      }
    },
    "notes": {
      "type": "markdown"
    },
    "stoichiometry": {
      "type": "reactionParticipants"
    },
    "reaction": {
      "type": "internalLink",
      "formattingRules": {
        "nameKey": "name",
        "linkTemplate": "/${type}/${id}"
      }
    }
  },
  "joinResources": {
    "chemical": "*, synonym(*), reaction(*)",
    "reaction": "*, stoichiometry(*, chemical(*)), synonym(*)",
    "protein": "*, synonym(*)"
  },
  "joinLimits": {
    "chemical": { "reaction": 5 }
  },
  "plural": {
    "chemical": "chemicals",
    "reaction": "reactions",
    "species": "species",
    "synonym": "synonyms",
    "protein": "proteins"
  },
  "specialCapitalize": {
    "inchi": "InChI",
    "inchi_key": "InChI Key",
    "ncbi_tax_id": "NCBI Tax ID",
    "short_name": "Short Name",
    "uniprot": "UniProt",
    "metacyc": "MetaCyc",
    "rhea": "RHEA",
    "chebi": "ChEBI"
  },
  "icon": {
    "chemical": "co2",
    "reaction": "syncAlt",
    "species": "emojiNature",
    "protein": "gesture"
  }
}
